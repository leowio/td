#!/bin/bash
# Toggle a temporary workspace showing all AI windows from td workspaces

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
TD_WINDOW_STATE_CMD="$SCRIPT_DIR/td-window-state"

WS_NAME="td-ai-overview"

# Toggle off if overview workspace has windows
overview=$(hyprctl clients -j | jq -r --arg ws "$WS_NAME" \
    '.[] | select(.workspace.name == $ws) | [.address, (.pid | tostring)] | @tsv')

if [[ -n "$overview" ]]; then
    focused=$(hyprctl activewindow -j | jq -r '.address')
    batch=""
    while IFS=$'\t' read -r addr pid; do
        original_ws=$("$TD_WINDOW_STATE_CMD" get "$pid" 2>/dev/null | awk -F'\t' 'NR == 1 { print $2 }')
        [[ -n "$original_ws" ]] || continue
        batch+="dispatch movetoworkspacesilent name:$original_ws, address:$addr ;"
    done <<< "$overview"
    batch+="dispatch workspace previous ;"
    batch+="dispatch focuswindow address:$focused"
    hyprctl --batch "$batch"
    exit 0
fi

# Toggle on: find AI windows across all td workspaces
batch=""
while IFS=$'\t' read -r pid workspace role created_at; do
    [[ "$role" == "ai" ]] || continue
    addr=$(hyprctl clients -j | jq -r --arg pid "$pid" '.[] | select((.pid | tostring) == $pid) | .address' | head -1)
    [[ -n "$addr" ]] || continue
    batch+="dispatch movetoworkspacesilent name:$WS_NAME, address:$addr ;"
done < <("$TD_WINDOW_STATE_CMD" list)

[[ -z "$batch" ]] && exit 0

batch+="dispatch workspace name:$WS_NAME"
hyprctl --batch "$batch"
