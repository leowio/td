#!/bin/bash
# Spawn td windows in a 3-column layout: editor 50% | ai 25% | term1/term2 25%
# Usage: td-layout <class> <dir> [ai_cmd]

cls=$1
dir=$2
ai_cmd=${3:-${TD_AI_CMD:-claude --dangerously-skip-permissions}}

# Idempotent: if workspace already exists with our windows, just switch
existing=$(hyprctl workspaces -j | jq -r --arg c "$cls" \
    '.[] | select(.name == $c) | .id')
if [[ -n "$existing" ]]; then
    hyprctl dispatch workspace "name:$cls"
    exit 0
fi

# Switch to (or create) the named workspace
hyprctl dispatch workspace "name:$cls"
sleep 0.1

wait_for() {
    local count=$1
    for _ in $(seq 1 50); do
        current=$(hyprctl clients -j | jq --arg c "$cls" '[.[] | select(.class == $c)] | length')
        [[ $current -ge $count ]] && return 0
        sleep 0.1
    done
}

window_role() {
    local pid=$1
    local environ="/proc/$pid/environ"
    [[ -r "$environ" ]] || return 1
    tr '\0' '\n' < "$environ" | awk -F= '$1 == "TD_ROLE" { print $2; exit }'
}

# 1. editor (full screen)
hyprctl dispatch exec "env TD_ROLE=editor uwsm-app -- alacritty --class $cls --working-directory '$dir' -e sh -lc '\${EDITOR:-nvim} .; exec \$SHELL'"
wait_for 1
sleep 0.1

# 2. preselect right → AI goes right of editor: [editor | AI]
hyprctl dispatch layoutmsg "preselect r"
hyprctl dispatch exec "env TD_ROLE=ai uwsm-app -- alacritty --class $cls --working-directory '$dir' -e sh -c '$ai_cmd; exec \$SHELL'"
wait_for 2
sleep 0.1

# 3. preselect right → term1 goes right of AI: [editor | AI | term1]
hyprctl dispatch layoutmsg "preselect r"
hyprctl dispatch exec "env TD_ROLE=term uwsm-app -- alacritty --class $cls --working-directory '$dir'"
wait_for 3
sleep 0.1

# 4. preselect down → term2 goes below term1: [editor | AI | term1/term2]
hyprctl dispatch layoutmsg "preselect d"
hyprctl dispatch exec "env TD_ROLE=term uwsm-app -- alacritty --class $cls --working-directory '$dir'"
wait_for 4
sleep 0.2

# 5. Resize editor column to 1/2
editor_addr=""
while IFS= read -r line; do
    addr=$(echo "$line" | jq -r '.address')
    pid=$(echo "$line" | jq -r '.pid')
    if [[ "$(window_role "$pid")" == "editor" ]]; then
        editor_addr="$addr"
        break
    fi
done < <(hyprctl clients -j | jq -c --arg c "$cls" '.[] | select(.class == $c)')

if [[ -n "$editor_addr" ]]; then
    hyprctl dispatch focuswindow "address:$editor_addr"
    sleep 0.05
    hyprctl dispatch splitratio "exact 0.5"
fi
