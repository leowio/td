#!/bin/bash
ws=$(hyprctl activeworkspace -j | jq -r '.name')
if [[ "$ws" == td-* ]]; then
    cwd=$(omarchy-cmd-terminal-cwd)
    exec env TD_ROLE=term uwsm-app -- alacritty --class "$ws" --working-directory "${cwd:-$HOME}"
else
    exec uwsm-app -- xdg-terminal-exec --dir="$(omarchy-cmd-terminal-cwd)"
fi
