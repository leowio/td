#!/bin/bash
# td-ai-status - Waybar module showing AI agent status per td workspace
#
# Each workspace shows: [name] 󰚩󰚩…  (one icon per detected agent)
#   busy      → icon pulses via CSS
#   attention → icon bright, pinned to theme fg
#   no agents → just the name pill, no icons

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
TD_WINDOW_STATE_CMD="$SCRIPT_DIR/td-window-state"

ICON="󰚩"
MAX_LABEL=8
STATE_DIR="${TD_AI_STATE_DIR:-${XDG_RUNTIME_DIR:-/tmp}/td-ai-state}"
DEAD_GRACE=5

# --- Supported AI agents ---
AI_TITLE_KEYWORDS="codex|aider|cursor"           # window title keywords (case-insensitive)
BRAILLE_PATTERN='[\x{2801}-\x{28FF}]'            # spinner in title → busy

# --- Theme ---
fg=$(grep -oP '(?<=@define-color foreground )#[0-9a-fA-F]+' \
    ~/.config/omarchy/current/theme/waybar.css)
fg=${fg:-#cdd6f4}

# --- Pango helpers ---
pill() { echo "<span color='$fg' background='$fg' bgalpha='15%'> $1 </span>"; }

truncate() {
    local s="$1"
    (( ${#s} > MAX_LABEL )) && echo "${s:0:$MAX_LABEL}…" || echo "$s"
}

add_agent() {
    local ws="$1"
    local name="$2"
    local state="$3"
    agent_names+=("$name")
    agent_states+=("$state")
    seen_agents["$ws:$name"]=1
}

detect_wrapped_agents() {
    local ws="$1"
    local now
    now=$(date +%s)

    [[ -d "$STATE_DIR" ]] || return 1

    local file workspace name state pid updated_at source
    local found=1
    for file in "$STATE_DIR"/*.state; do
        [[ -e "$file" ]] || continue
        IFS=$'\t' read -r workspace name state pid updated_at source < "$file" || continue
        [[ "$workspace" == "$ws" ]] || continue

        if ! kill -0 "$pid" 2>/dev/null; then
            rm -f "$file"
            continue
        fi

        if [[ -n "$updated_at" ]]; then
            local updated_epoch=${updated_at%%.*}
            if (( now - updated_epoch > DEAD_GRACE )); then
                state="dead"
            fi
        fi

        case "$state" in
            dead)
                rm -f "$file"
                continue
                ;;
            busy|attention|idle)
                add_agent "$ws" "$name" "$state"
                found=0
                ;;
        esac
    done

    return "$found"
}

detect_fallback_agents() {
    local ws="$1"
    local pid workspace role created_at title state name

    while IFS=$'\t' read -r pid workspace role created_at; do
        [[ "$role" == "ai" ]] || continue
        local state="attention"
        title=$(echo "$clients_json" | jq -r --arg pid "$pid" '.[] | select((.pid | tostring) == $pid) | .title' | head -1)
        echo "$title" | grep -qP "$BRAILLE_PATTERN" && state="busy"

        name=$(echo "$title" | grep -oiP "$AI_TITLE_KEYWORDS" | head -1 | tr '[:upper:]' '[:lower:]')
        [[ -z "$name" ]] && name="ai"
        [[ -n "${seen_agents["$ws:$name"]}" ]] && continue
        add_agent "$ws" "$name" "$state"
    done < <("$TD_WINDOW_STATE_CMD" list --workspace "$ws" --role ai)
}

# --- Main ---
workspaces=$(hyprctl workspaces -j 2>/dev/null \
    | jq -r '.[] | .name' \
    | grep '^td-' \
    | grep -v '^td-ai-overview$' \
    | sort)

if [[ -z "$workspaces" ]]; then
    echo '{"text": "", "tooltip": "", "class": "empty"}'
    exit 0
fi

clients_json=$(hyprctl clients -j 2>/dev/null)

text_parts=()
tooltip_parts=()
has_busy=false
has_attention=false
declare -A seen_agents

for ws in $workspaces; do
    short="${ws#td-}"
    label=$(truncate "$short")

    agent_names=()
    agent_states=()
    detect_wrapped_agents "$ws" || true
    if (( ${#agent_names[@]} == 0 )); then
        detect_fallback_agents "$ws"
    fi

    icons=""
    tip_agents=()
    for i in "${!agent_names[@]}"; do
        case "${agent_states[$i]}" in
            busy)      has_busy=true;     icons+=" $ICON" ;;
            attention|idle) has_attention=true; icons+=" <span color='$fg'>$ICON</span>" ;;
        esac
        tip_agents+=("${agent_names[$i]}:${agent_states[$i]}")
    done

    text_parts+=("$(pill "$label")$icons")

    if (( ${#agent_names[@]} > 0 )); then
        tooltip_parts+=("$short: $(IFS=', '; echo "${tip_agents[*]}")")
    else
        tooltip_parts+=("$short: no agents")
    fi
done

# Join workspaces with double space
text=$(IFS='|'; echo "${text_parts[*]}")
text="${text//|/  }"

tooltip=$(printf '%s\\n' "${tooltip_parts[@]}")
tooltip="${tooltip%\\n}"

# CSS class
classes=()
$has_busy      && classes+=("busy")
$has_attention && classes+=("attention")

case ${#classes[@]} in
    0) class_json='"idle"' ;;
    1) class_json="\"${classes[0]}\"" ;;
    *) class_json="[\"${classes[0]}\", \"${classes[1]}\"]" ;;
esac

printf '{"text": "%s", "tooltip": "%s", "class": %s}\n' "$text" "$tooltip" "$class_json"
