#!/bin/bash
# td-browser - launch and track a browser window in the current td workspace
# Usage: td-browser [url]

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
TD_WINDOW_STATE_CMD="$SCRIPT_DIR/td-window-state"

window_role() {
    local pid="$1"
    "$TD_WINDOW_STATE_CMD" get "$pid" 2>/dev/null | awk -F'\t' 'NR == 1 { print $3 }'
}

editor_addr() {
    while IFS= read -r line; do
        local addr pid role
        addr=$(echo "$line" | jq -r '.address')
        pid=$(echo "$line" | jq -r '.pid')
        role=$(window_role "$pid")
        if [[ "$role" == "editor" ]]; then
            printf '%s\n' "$addr"
            return 0
        fi
    done < <(hyprctl clients -j | jq -c --arg ws "$ws" '.[] | select(.workspace.name == $ws)')
}

default_browser_desktop() {
    xdg-settings get default-web-browser 2>/dev/null || true
}

desktop_file_path() {
    local desktop_id="$1"
    local path

    for path in "$HOME/.local/share/applications/$desktop_id" "/usr/share/applications/$desktop_id"; do
        [[ -r "$path" ]] && printf '%s\n' "$path" && return 0
    done

    return 1
}

desktop_exec() {
    local desktop_file="$1"
    sed -n 's/^Exec=//p' "$desktop_file" | head -1
}

launch_browser_window() {
    local target="$1"
    local desktop_id desktop_file exec_line browser_cmd

    desktop_id=$(default_browser_desktop)
    if [[ -n "$desktop_id" ]] && desktop_file=$(desktop_file_path "$desktop_id"); then
        exec_line=$(desktop_exec "$desktop_file")
        browser_cmd=${exec_line%% *}
    else
        browser_cmd=""
    fi

    case "$(basename "$browser_cmd")" in
        helium-browser|chromium|chromium-browser|google-chrome|google-chrome-stable|brave|brave-browser|microsoft-edge|microsoft-edge-stable|zen-browser)
            "$browser_cmd" --new-window "$target" >/dev/null 2>&1 &
            return 0
            ;;
        firefox|firefox-bin)
            "$browser_cmd" --new-window "$target" >/dev/null 2>&1 &
            return 0
            ;;
        qutebrowser)
            "$browser_cmd" "$target" >/dev/null 2>&1 &
            return 0
            ;;
    esac

    xdg-open "$target" >/dev/null 2>&1 &
}

ws=$(hyprctl activeworkspace -j | jq -r '.name')
if [[ "$ws" != td-* ]]; then
    exec omarchy-launch-browser ${1:+"$1"}
fi

target="${1:-about:blank}"
active_before=$(hyprctl activewindow -j | jq -r '.address // empty')
clients_before=$(hyprctl clients -j)
editor_addr=$(editor_addr || true)

if [[ -n "$editor_addr" ]]; then
    hyprctl dispatch focuswindow "address:$editor_addr"
    sleep 0.05
    hyprctl dispatch layoutmsg "preselect d"
fi

launch_browser_window "$target"

detect_browser_window() {
    local clients_after candidate active_after active_addr active_class
    clients_after=$(hyprctl clients -j)

    candidate=$(jq -r \
        --argjson before "$clients_before" \
        '
        [
          .[] as $client
          | select((($before | map(.address)) | index($client.address)) | not)
          | select($client.class != "Alacritty")
          | [$client.pid, $client.address, $client.workspace.name]
        ] | last // empty
        | if . == null then "" else @tsv end
        ' <<< "$clients_after")

    if [[ -n "$candidate" ]]; then
        printf '%s\n' "$candidate"
        return 0
    fi

    active_after=$(hyprctl activewindow -j)
    active_addr=$(jq -r '.address // empty' <<< "$active_after")
    active_class=$(jq -r '.class // empty' <<< "$active_after")

    if [[ -n "$active_addr" && "$active_addr" != "$active_before" && "$active_class" != "Alacritty" ]]; then
        jq -r '[.pid, .address, .workspace.name] | @tsv' <<< "$active_after"
        return 0
    fi

    return 1
}

browser_pid=""
browser_addr=""
browser_ws=""

for _ in $(seq 1 50); do
    if candidate=$(detect_browser_window); then
        IFS=$'\t' read -r browser_pid browser_addr browser_ws <<< "$candidate"
        [[ -n "$browser_pid" && -n "$browser_addr" ]] && break
    fi
    sleep 0.1
done

if [[ -z "$browser_pid" || -z "$browser_addr" ]]; then
    echo "Could not identify the browser window to track."
    exit 1
fi

if [[ "$browser_ws" != "$ws" ]]; then
    hyprctl dispatch movetoworkspacesilent "name:$ws, address:$browser_addr"
    sleep 0.1
fi

"$TD_WINDOW_STATE_CMD" register "$ws" browser "$browser_pid"
hyprctl dispatch focuswindow "address:$browser_addr"
